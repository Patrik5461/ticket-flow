    "@types/papaparse": "5.5.2",
    "@types/qrcode": "1.5.6",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "eslint": "9.39.5",
    "jsdom": "28.1.0",
    "prettier": "3.9.5",
    "supabase": "2.109.1",
