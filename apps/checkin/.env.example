# Ticketio Scan — build-time config (Vite inlines VITE_* into the bundle).
# Copy to .env before building the native app.

# Supabase project (same values as the main web app). The anon key is public
# and safe to ship in a client app — all access is RLS-protected.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...anon...

# Base URL of the Ticketio API the app calls (the check-in endpoint lives here).
VITE_API_BASE=https://ticketio.sk
