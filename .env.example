# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# === Supabase ===
# Project URL and keys. Service role key is server-only — never expose to the client.
#
# Aliases: the Lovable sandbox reserves the SUPABASE_ prefix for its own managed
# secrets, so there we cannot set our values under the original names. Every
# Supabase var therefore has a TICKETIO_-prefixed fallback. Precedence is
# SUPABASE_* first, then TICKETIO_SUPABASE_*. Set EITHER the plain name (local dev)
# OR the TICKETIO_ alias (Lovable sandbox).
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# TICKETIO_SUPABASE_URL=
# TICKETIO_SUPABASE_ANON_KEY=
# TICKETIO_SUPABASE_SERVICE_ROLE_KEY=

# === GoPay ===
# Inline payment gateway credentials. Use the sandbox environment during development.
GOPAY_GOID=
GOPAY_CLIENT_ID=
GOPAY_CLIENT_SECRET=
GOPAY_ENV=sandbox

# === App ===
# Public base URL of the app (used for return/webhook URLs, email links). No trailing slash.
APP_URL=http://localhost:3000
# Shared secret for internal cron endpoints (refund-queue worker). Also store this
# (and the endpoint URL) in the app_settings table so the pg_cron tick can call in.
CRON_SECRET=

# === Faktero (commission invoicing) ===
# Without both, invoicing logs instead of calling the API.
FAKTERO_API_KEY=
FAKTERO_API_URL=

# === Email (Resend) ===
# Without RESEND_API_KEY, email is logged to the console (dev).
# EMAIL_FROM must be on a Resend-verified domain (see README for SPF/DKIM).
RESEND_API_KEY=
EMAIL_FROM=Ticketio <noreply@ticketio.sk>

# === Wallet (optional) ===
# Apple Wallet — without all of these the "Apple Wallet" button is hidden.
# PEM values with literal \n for newlines.
APPLE_PASS_TYPE_ID=
APPLE_TEAM_ID=
APPLE_PASS_CERT_PEM=
APPLE_PASS_KEY_PEM=
APPLE_WWDR_PEM=
# Google Wallet — without all of these the "Google Wallet" button is hidden.
GOOGLE_WALLET_ISSUER_ID=
GOOGLE_WALLET_SA_EMAIL=
GOOGLE_WALLET_SA_KEY=

# AI support assistant (Anthropic). Without the key the support chat widget is
# hidden. SUPPORT_DAILY_LIMIT caps model calls per UTC day (0 = unlimited);
# once reached buyers get a static FAQ instead. Server-only, never client-side.
ANTHROPIC_API_KEY=
SUPPORT_DAILY_LIMIT=500
