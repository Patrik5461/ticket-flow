# SAMPLE production secrets for Ticketio.
#
# Per CLAUDE.md the REAL file lives on the VM at ~/ticketio-secrets.env and is
# NOT committed. Copy this template there, fill in real values, and load it via
# PM2 (node --env-file, see ecosystem.config.cjs). Never commit real secrets.
#
# Loaded at RUNTIME. Note: VITE_SITE_URL is a BUILD-TIME var — it must also be
# present in the environment when you run `npm run build` (it is baked into the
# client bundle), not only here.

# === Supabase ===
# Service role key is server-only — never expose it to the client.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# TICKETIO_-prefixed aliases (only needed in the Lovable sandbox):
# TICKETIO_SUPABASE_URL=
# TICKETIO_SUPABASE_ANON_KEY=
# TICKETIO_SUPABASE_SERVICE_ROLE_KEY=

# === App ===
# Public base URL — used for GoPay return/notification URLs and email links.
# No trailing slash.
APP_URL=https://ticketio.sk
# Canonical URL baked into SEO tags / sitemap / OG images. BUILD-TIME:
# export this before `npm run build` too (Vite inlines it).
VITE_SITE_URL=https://ticketio.sk

# === Cron ===
# Shared secret guarding /api/cron/* worker endpoints. MUST equal the value
# stored in app_settings.cron_secret (see README "Cron workers").
CRON_SECRET=

# === GoPay (payments) ===
# Set GOPAY_ENV=production for live payments; sandbox for testing.
GOPAY_GOID=
GOPAY_CLIENT_ID=
GOPAY_CLIENT_SECRET=
GOPAY_ENV=production

# === Email (Resend) ===
# Without RESEND_API_KEY the app logs emails instead of sending.
# EMAIL_FROM must be on a Resend-verified domain (configure SPF/DKIM/DMARC).
RESEND_API_KEY=
EMAIL_FROM=Ticketio <noreply@ticketio.sk>

# === Faktero (commission invoicing) ===
# Optional. Without both, invoicing logs instead of calling the API.
FAKTERO_API_KEY=
FAKTERO_API_URL=

# === Apple Wallet (.pkpass) ===
# Optional. Without ALL of these the "Add to Apple Wallet" button is hidden.
# PEM values: keep newlines as literal \n.
APPLE_PASS_TYPE_ID=
APPLE_TEAM_ID=
APPLE_PASS_CERT_PEM=
APPLE_PASS_KEY_PEM=
APPLE_WWDR_PEM=

# === Google Wallet ===
# Optional. Without ALL of these the "Save to Google Wallet" button is hidden.
GOOGLE_WALLET_ISSUER_ID=
GOOGLE_WALLET_SA_EMAIL=
GOOGLE_WALLET_SA_KEY=
